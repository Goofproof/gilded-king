#!/bin/sh
# Blocks a push that ships game changes with no patch-notes entry.
#
# js/patchnotes.js NOTES[0].sha is the commit the newest entry shipped at. If
# anything under js/ index.html style.css assets/ server/ changed since then,
# the notes are stale and players would get a silent update. This is how 87
# commits - five new classes, the global leaderboard, 118 accolades, real room
# shapes - went live unannounced between v2.13 and v2.14.
#
# Fix: npm run notes -- --title "Headline"   (or `npm run ship`, which does
# notes + test + commit + push in one go). Genuinely need to bypass? --no-verify.
#
# Installed via: git config core.hooksPath .githooks

# --- TEST GATE ---------------------------------------------------------------
# Run the suite on every push, not just `npm run ship`. This is what keeps the
# mobile guards (test/touch.test.js + test/mobile-states.test.js) - and the seed-
# determinism co-op depends on - from being bypassed by a plain `git push`. A future
# patch that adds a keyboard-only screen fails HERE, before players ever see it.
# If node/npm is not on PATH in this hook's shell, warn and defer to the ship gate
# rather than block a push on a missing toolchain. Genuinely need to bypass? --no-verify.
if command -v npm >/dev/null 2>&1; then
  echo "pre-push: running npm test ..." >&2
  if ! npm test --silent >&2; then
    echo "" >&2
    echo "  PUSH BLOCKED - tests failed. Fix them (or --no-verify if you truly mean to)." >&2
    echo "" >&2
    exit 1
  fi
else
  echo "pre-push: npm not on PATH - skipping tests here (npm run ship still gates them)." >&2
fi
# -----------------------------------------------------------------------------

sha=$(grep -m1 -o "sha: '[0-9a-f]\{7,40\}'" js/patchnotes.js | grep -o "[0-9a-f]\{7,40\}")
if [ -z "$sha" ]; then
  echo "pre-push: js/patchnotes.js NOTES[0] has no sha - cannot tell what is unreleased." >&2
  exit 1
fi
if ! git cat-file -e "$sha^{commit}" 2>/dev/null; then
  echo "pre-push: patch-notes sha $sha is not a commit here - skipping the check." >&2
  exit 0
fi

# Game files changed since the last entry (the notes file itself does not count).
#
# A commit whose subject carries [skip-notes] is EXEMPT - and it has to be, or the
# guard is unpassable for work that is genuinely invisible to a player (a comment, a
# typo, a test-only refactor of a js/ file). The notes GENERATOR already filters
# those commits out; the hook did not know about them, so a chore commit touching js/
# could only ever be pushed by inventing a version nobody needed. That is not a
# guarantee, it is a tax.
#
# The bar is unchanged: a change is either IN THE NOTES, or it explicitly declares
# itself invisible. It can never be silent by accident, which is the whole point.
#
# BATCHING (Sam): notes are no longer cut one-per-push - that made them read as an
# endless list of tiny bumps. The generator holds player-visible changes until a
# handful stack up, then releases them as one themed update. So this guard must ALLOW
# a few un-noted game changes to accumulate, and only block once enough have piled up
# that an entry is due. BATCH must match scripts/patchnotes.mjs.
BATCH=4
count=0
changed=""
for cmt in $(git rev-list "$sha"..HEAD); do
  subj=$(git log -1 --format=%s "$cmt")
  lsub=$(printf '%s' "$subj" | tr 'A-Z' 'a-z')
  case "$lsub" in
    *"[skip-notes]"*) continue ;;
    "patch notes"*|notes:*|chore*|test*|doc*|refactor*|wip*|merge*|revert*|bump*|ci*) continue ;;
  esac
  files=$(git show --name-only --format= "$cmt" -- js index.html style.css assets server | grep -v '^js/patchnotes\.js$')
  if [ -n "$files" ]; then
    count=$((count + 1))
    changed="$changed$files
"
  fi
done

if [ "$count" -ge "$BATCH" ]; then
  echo "" >&2
  echo "  PUSH BLOCKED - $count player-visible changes have stacked up since patch notes $sha." >&2
  echo "  That is enough for an update ($BATCH+). Cut the themed entry before pushing:" >&2
  echo "" >&2
  printf '%s' "$changed" | grep -v '^$' | sort -u | sed 's/^/    /' >&2
  echo "" >&2
  echo "  Run:  npm run ship            (auto-titles + batches features, bundles fixes)" >&2
  echo "  Or:   npm run ship -- --title \"Your Headline\"   (curate the headline yourself)" >&2
  echo "" >&2
  exit 1
fi
# fewer than BATCH un-noted changes: still accumulating, let the push through.
exit 0
