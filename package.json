{
  "name": "gilded-king",
  "version": "2.5.0",
  "private": true,
  "description": "Dungeon of the Gilded King - a vanilla-JS canvas roguelike (no build step for the game itself; this package.json only wires the dev test harness).",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "notes": "node scripts/patchnotes.mjs",
    "ship": "node scripts/publish.mjs",
    "postinstall": "git config core.hooksPath .githooks",
    "deploy": "wrangler deploy -c server/wrangler.toml",
    "preview": "wrangler dev -c server/wrangler.toml",
    "deploy:check": "wrangler deploy -c server/wrangler.toml --dry-run"
  },
  "devDependencies": {
    "vitest": "^2.1.9",
    "wrangler": "^4.110.0"
  }
}
